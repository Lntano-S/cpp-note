{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "g++ - 调试当前活动文件",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}", // 关键：动态指向当前文件的编译产物
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: g++ 生成活动文件", // 关键：调试前自动运行编译任务
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}